# === OBRIGATÓRIOS ===

# Firebase Web SDK (valores do Firebase Console)
FIREBASE_API_KEY=AIzaSy...
FIREBASE_AUTH_DOMAIN=meu-projeto.firebaseapp.com
FIREBASE_PROJECT_ID=meu-projeto
FIREBASE_STORAGE_BUCKET=meu-projeto.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abc123def456

# Chave de criptografia das sessões
# Gerar com: python -c "import secrets; print(secrets.token_hex(32))"
RADAR_SOLAR_STORAGE_SECRET=

# === OPCIONAIS (com defaults seguros) ===

# Origens CORS permitidas (separadas por vírgula)
# ALLOWED_ORIGINS=http://localhost:8080

# Forçar HTTPS (cookies Secure, HSTS header)
# FORCE_HTTPS=false

# Rate limit: requisições por janela (segundos)
# RATE_LIMIT_REQUESTS=60
# RATE_LIMIT_WINDOW=60

# Host/porta do servidor (0.0.0.0 para Docker/produção)
# SERVER_HOST=localhost
# SERVER_PORT=8080

# PostgreSQL (opcional: se vazio, usa SQLite local)
# Ex: postgresql://usuario:senha@localhost:5432/radarsolar
# DATABASE_URL=
